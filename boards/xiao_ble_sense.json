{
  "build": {
    "cpu": "cortex-m4",
    "f_cpu": "64000000L",
    "mcu": "nrf52840",
    "zephyr": {
      "variant": "nrf52840dk_nrf52840"
    },
    "softdevice": {
      "sd_flags": "-DNRF52840_XXAA",
      "sd_fwid": "0x0000"
    }
  },
  "connectivity": ["bluetooth"],
  "debug": {
    "jlink_device": "nRF52840_xxAA",
    "svd_path": "nrf52840.svd"
  },
  "frameworks": ["zephyr"],
  "name": "Seeed Studio XIAO nRF52840 Sense",
  "upload": {
    "maximum_ram_size": 262144,
    "maximum_size": 1048576,
    "protocol": "nrfjprog",
    "protocols": ["jlink", "nrfjprog", "blackmagic"]
  },
  "url": "https://wiki.seeedstudio.com/XIAO_BLE/",
  "vendor": "Seeed Studio"
}
