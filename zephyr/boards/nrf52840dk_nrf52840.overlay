/*
 * Device tree overlay for Seeed XIAO nRF52840 Sense
 *
 * Pin sources:
 *   i2c0 SDA=P0.07 SCL=P0.27 — from zephyrproject-rtos/zephyr
 *       boards/seeed/xiao_ble/xiao_ble-pinctrl.dtsi
 *   IMU power P1.08 — from Seeed schematic
 *   GPIO hog: drives P1.08 high at GPIO init (before I2C and sensor drivers)
 *   H0H1 drive via extra-flags = <NRF_GPIO_DRIVE_H0H1> removed (Zephyr 2.7 unsupported)
 *   buttons removed: P0.27 is I2C SCL, P0.11 is INT1
 */

/ {
    leds {
        compatible = "gpio-leds";
        led_status: led_0 {
            gpios = <&gpio0 13 GPIO_ACTIVE_LOW>;
            label = "Status LED";
        };
    };
};

&gpio1 {
    imu-pwr-hog {
        gpio-hog;
        gpios = <8 GPIO_ACTIVE_HIGH>;
        output-high;
    };
};

&i2c0 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    sda-pin = <7>;
    scl-pin = <27>;
    clock-frequency = <400000>;

    lsm6dso: lsm6ds3tr_c@6a {
        compatible = "st,lsm6dsl";
        reg = <0x6a>;
        status = "okay";
        label = "LSM6DSL";
    };
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};
